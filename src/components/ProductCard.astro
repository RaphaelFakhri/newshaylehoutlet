---
import type { Lang } from '../i18n/translations';

interface Props {
  lang: Lang;
  slug: string;
  name: string;
  image: string;
  category: string;
}
const { lang, slug, name, image, category } = Astro.props;
---

<a href={`/${lang}/shop/${slug}/`} class="group block">
  <div class="aspect-[3/4] overflow-hidden bg-ink/5 rounded-md">
    <img
      src={image}
      alt={name}
      class="h-full w-full object-cover group-hover:scale-105 transition duration-500"
      loading="lazy"
    />
  </div>
  <div class="mt-3">
    <div class="text-xs uppercase tracking-wider text-ink/50">{category}</div>
    <div class="mt-1 font-serif text-lg leading-tight">{name}</div>
  </div>
</a>
